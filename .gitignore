# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Ignore the .terraform directory, which stores downloaded providers and modules
.terraform/

# Ignore Terraform state files and backups (best practice is to use a remote backend)
*.tfstate
*.tfstate.*.backup

# Ignore tfplan files (plan output of command: terraform plan -out=tfplan)
# example: *tfplan*

# Ignore crash log files
crash.log
crash.*.log

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: Ignore all .tfvars files, as they may contain sensitive data
# You should use a secrets management tool or environment variables instead
# *.tfvars
# *.tfvars.json

# Ignore override files used for local development
# override.tf
# override.tf.json
# *_override.tf
# *_override.tf.json

.DS_Store